{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "file-manager",
  "version": "0.1.0",
  "identifier": "eu.manwol.file-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "file-manager",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwQTNGQTg5NUVENzJBRUQKUldUdEt0ZGVpZnFqY0Rxdmk4KzVzL3NIaHZ5SEpIci84T3lUMUpBdGlMQVRsRE5hOEhiSk1LbWUK",
      "endpoints": ["https://github.com/yawnwest/file-manager/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
