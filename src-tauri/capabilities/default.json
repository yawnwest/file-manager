{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "dialog:default",
    "fs:default",
    "updater:default",
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    }
  ]
}
